        .agency-name { font-size: 20px; font-weight: 700; background: linear-gradient(to right, #FFF, var(--accent-gold)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        
        nav ul { list-style: none; display: flex; gap: 25px; margin: 0; align-items: center; padding: 0;}
        nav ul li a { font-size: 13px; font-weight: 500; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; transition: var(--transition); }
        nav ul li a:hover { color: white; text-shadow: 0 0 8px var(--accent-glow); }
        .phone-link { border: 1px solid var(--accent-gold); padding: 8px 18px; border-radius: 30px; color: var(--accent-gold) !important; }

        .hero { padding: 140px 20px; text-align: center; }
        .hero h1 { font-size: clamp(40px, 6vw, 64px); font-weight: 700; margin-bottom: 20px; background: linear-gradient(135deg, #FFF 0%, var(--accent-gold) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .hero p { font-size: 18px; color: var(--text-muted); max-width: 700px; margin: 0 auto; }

        .page-section { padding: 80px 5%; max-width: 1200px; margin: 0 auto; }
        .section-title { text-align: center; margin-bottom: 50px; }
        .section-title h2 { font-size: 32px; color: white; margin-bottom: 10px; }
        .section-title p { color: var(--accent-gold); text-transform: uppercase; letter-spacing: 2px; font-size: 12px; }

        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 25px; }
        .aura-card { background: rgba(255,255,255,0.03); border: 1px solid var(--border-glass); padding: 30px; border-radius: 20px; transition: var(--transition); backdrop-filter: blur(10px); }
        .aura-card:hover { border-color: var(--accent-gold); transform: translateY(-5px); box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .aura-card h3 { font-size: 18px; color: white; margin-top: 0; display: flex; align-items: center; gap: 10px; }
        .aura-card p { font-size: 14px; color: var(--text-muted); white-space: pre-line; }

        .data-table { width: 100%; border-collapse: collapse; margin-top: 20px; font-size: 14px; }
        .data-table tr { border-bottom: 1px solid var(--border-glass); }
        .data-table td { padding: 12px 5px; color: var(--text-muted); }
        .data-table td:last-child { text-align: right; color: var(--accent-gold); font-weight: 600; }
        body[dir="rtl"] .data-table td:last-child { text-align: left; }

        .highlight-box { background: linear-gradient(145deg, rgba(197,160,89,0.1), transparent); border: 1px solid var(--accent-gold); border-radius: 20px; padding: 40px; margin-top: 40px; text-align: center; }
        .pill { background: rgba(255,255,255,0.05); padding: 5px 12px; border-radius: 20px; font-size: 12px; border: 1px solid var(--border-glass); margin: 5px; display: inline-block; color: white; }

        .social-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 40px; }
        .social-btn { display: flex; align-items: center; justify-content: center; gap: 10px; padding: 20px; border-radius: 15px; border: 1px solid var(--border-glass); background: rgba(255,255,255,0.02); transition: var(--transition); font-weight: 600; color: white; }
        .social-btn:hover { background: rgba(197, 160, 89, 0.1); border-color: var(--accent-gold); transform: scale(1.02); }

        .fade-in { opacity: 0; transform: translateY(20px); transition: 0.8s ease-out; }
        .fade-in.appear { opacity: 1; transform: translateY(0); }

        footer { padding: 40px; text-align: center; border-top: 1px solid var(--border-glass); color: var(--text-muted); font-size: 12px; margin-top: 60px; }

